{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dustcult-net",
  "compatibility_date": "2026-05-14",
  "assets": {
    "directory": "./_site",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "routes": [
    {
      "pattern": "dustcult.net/*",
      "zone_name": "dustcult.net"
    }
  ]
}
